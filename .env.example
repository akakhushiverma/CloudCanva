# ============================================
# CloudCanva Environment Variables
# ============================================
# Copy the relevant sections to:
#   frontend/.env.local  (for Next.js)
#   backend/.env         (for FastAPI)
#
# Replace placeholder values with your own AWS resources.

# ─── FRONTEND (frontend/.env.local) ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-region_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-app-client-id

# ─── BACKEND (backend/.env) ─────────────────────────────────────
AWS_REGION=eu-north-1
S3_BUCKET=your-s3-bucket-name
COGNITO_REGION=your-cognito-region
COGNITO_USER_POOL_ID=your-region_xxxxxxxxx
COGNITO_APP_CLIENT_ID=your-cognito-app-client-id
